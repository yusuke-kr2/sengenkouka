<% content_for :title, "ユーザー管理 - sengen" %>

<!-- ナビバー -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-900 border-b border-gray-700">
  <div class="mx-auto px-6 h-16 flex justify-between items-center max-w-5xl">
    <div class="flex items-center gap-6">
      <span class="text-white font-bold text-lg">sengen Admin</span>
      <%= link_to "ダッシュボード", admin_root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= link_to "ユーザー", admin_users_path, class: "text-white text-sm font-semibold" %>
      <%= link_to "宣言", admin_declarations_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "サイトへ", root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "border border-gray-600 text-gray-300 rounded-lg px-4 py-1.5 text-sm hover:bg-gray-800 transition-colors cursor-pointer" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-50 pt-16">
  <div class="max-w-5xl mx-auto px-6 py-8">

    <!-- フラッシュメッセージ -->
    <% if notice %>
      <div class="bg-blue-50 border border-blue-200 text-blue-700 rounded-xl px-4 py-3 text-sm mb-4 flex items-center justify-between">
        <span><%= notice %></span>
        <button onclick="this.parentElement.remove()" class="ml-3 text-blue-400 hover:text-blue-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-4 flex items-center justify-between">
        <span><%= alert %></span>
        <button onclick="this.parentElement.remove()" class="ml-3 text-red-400 hover:text-red-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    <% end %>

    <h1 class="text-2xl font-bold text-gray-800 mb-6">ユーザー管理 (<%= @users.count %>人)</h1>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">ユーザー</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">メール</th>
            <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase">宣言数</th>
            <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase">ストリーク</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">登録日</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @users.each do |user| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3">
                <div class="flex items-center gap-3">
                  <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0 overflow-hidden">
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, class: "h-full w-full object-cover" %>
                    <% else %>
                      <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                      </svg>
                    <% end %>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-800"><%= user.name %></p>
                    <% if user.admin? %>
                      <span class="text-xs text-orange-600 font-medium">管理者</span>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="px-5 py-3 text-sm text-gray-600"><%= user.email %></td>
              <td class="px-5 py-3 text-sm text-gray-600 text-center"><%= user.declarations.count %></td>
              <td class="px-5 py-3 text-sm text-gray-600 text-center"><%= user.streak_count %></td>
              <td class="px-5 py-3 text-sm text-gray-400"><%= user.created_at.strftime("%Y/%m/%d") %></td>
              <td class="px-5 py-3 text-right">
                <% unless user == current_user %>
                  <%= button_to "削除", admin_user_path(user), method: :delete,
                      data: { turbo_confirm: "#{user.name}を本当に削除しますか？" },
                      class: "text-red-500 text-sm hover:text-red-700 transition-colors cursor-pointer" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>
