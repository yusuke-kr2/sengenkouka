<% content_for :title, "管理画面 - sengen" %>

<!-- ナビバー -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-900 border-b border-gray-700">
  <div class="mx-auto px-6 h-16 flex justify-between items-center max-w-5xl">
    <div class="flex items-center gap-6">
      <span class="text-white font-bold text-lg">sengen Admin</span>
      <%= link_to "ダッシュボード", admin_root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= link_to "ユーザー", admin_users_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= link_to "宣言", admin_declarations_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "サイトへ", root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "border border-gray-600 text-gray-300 rounded-lg px-4 py-1.5 text-sm hover:bg-gray-800 transition-colors cursor-pointer" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-50 pt-16">
  <div class="max-w-5xl mx-auto px-6 py-8">

    <h1 class="text-2xl font-bold text-gray-800 mb-6">ダッシュボード</h1>

    <!-- 統計カード -->
    <div class="grid grid-cols-5 gap-4 mb-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 text-center">
        <p class="text-3xl font-bold text-gray-800"><%= @total_users %></p>
        <p class="text-sm text-gray-400 mt-1">ユーザー数</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 text-center">
        <p class="text-3xl font-bold text-gray-800"><%= @total_declarations %></p>
        <p class="text-sm text-gray-400 mt-1">総宣言数</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 text-center">
        <p class="text-3xl font-bold text-blue-600"><%= @total_declaring %></p>
        <p class="text-sm text-gray-400 mt-1">宣言中</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 text-center">
        <p class="text-3xl font-bold text-green-600"><%= @total_completed %></p>
        <p class="text-sm text-gray-400 mt-1">達成</p>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 text-center">
        <p class="text-3xl font-bold text-red-600"><%= @total_pending %></p>
        <p class="text-sm text-gray-400 mt-1">未達成</p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6">
      <!-- 最近のユーザー -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-bold text-gray-800">最近のユーザー</h2>
          <%= link_to "すべて見る", admin_users_path, class: "text-blue-600 text-sm hover:underline" %>
        </div>
        <div class="space-y-3">
          <% @recent_users.each do |user| %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0 overflow-hidden">
                  <% if user.avatar.attached? %>
                    <%= image_tag user.avatar, class: "h-full w-full object-cover" %>
                  <% else %>
                    <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  <% end %>
                </div>
                <div>
                  <p class="text-sm font-semibold text-gray-800"><%= user.name %></p>
                  <p class="text-xs text-gray-400"><%= user.email %></p>
                </div>
              </div>
              <p class="text-xs text-gray-400"><%= user.created_at.strftime("%Y/%m/%d") %></p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- 最近の宣言 -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-bold text-gray-800">最近の宣言</h2>
          <%= link_to "すべて見る", admin_declarations_path, class: "text-blue-600 text-sm hover:underline" %>
        </div>
        <div class="space-y-3">
          <% @recent_declarations.each do |declaration| %>
            <div class="flex items-center justify-between">
              <div class="min-w-0 flex-1">
                <p class="text-sm text-gray-800 truncate"><%= declaration.content %></p>
                <p class="text-xs text-gray-400"><%= declaration.user.name %> / <%= declaration.deadline.strftime("%Y/%m/%d") %></p>
              </div>
              <span class="ml-3 text-xs px-2 py-1 rounded-full shrink-0 <%= case declaration.status when 'declaring' then 'bg-blue-50 text-blue-600' when 'completed' then 'bg-green-50 text-green-600' when 'pending' then 'bg-red-50 text-red-600' end %>">
                <%= case declaration.status when 'declaring' then '宣言中' when 'completed' then '達成' when 'pending' then '未達成' end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>
