<% content_for :title, "宣言管理 - sengen" %>

<!-- ナビバー -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-gray-900 border-b border-gray-700">
  <div class="mx-auto px-6 h-16 flex justify-between items-center max-w-5xl">
    <div class="flex items-center gap-6">
      <span class="text-white font-bold text-lg">sengen Admin</span>
      <%= link_to "ダッシュボード", admin_root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= link_to "ユーザー", admin_users_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= link_to "宣言", admin_declarations_path, class: "text-white text-sm font-semibold" %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "サイトへ", root_path, class: "text-gray-300 text-sm hover:text-white transition-colors" %>
      <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "border border-gray-600 text-gray-300 rounded-lg px-4 py-1.5 text-sm hover:bg-gray-800 transition-colors cursor-pointer" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-50 pt-16">
  <div class="max-w-5xl mx-auto px-6 py-8">

    <!-- フラッシュメッセージ -->
    <% if notice %>
      <div class="bg-blue-50 border border-blue-200 text-blue-700 rounded-xl px-4 py-3 text-sm mb-4 flex items-center justify-between">
        <span><%= notice %></span>
        <button onclick="this.parentElement.remove()" class="ml-3 text-blue-400 hover:text-blue-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    <% end %>

    <h1 class="text-2xl font-bold text-gray-800 mb-6">宣言管理 (<%= @declarations.count %>件)</h1>

    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">内容</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">ユーザー</th>
            <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase">ステータス</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase">期限</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @declarations.each do |declaration| %>
            <tr class="hover:bg-gray-50">
              <td class="px-5 py-3 text-sm text-gray-800 max-w-xs truncate"><%= declaration.content %></td>
              <td class="px-5 py-3 text-sm text-gray-600"><%= declaration.user.name %></td>
              <td class="px-5 py-3 text-center">
                <span class="text-xs px-2 py-1 rounded-full <%= case declaration.status when 'declaring' then 'bg-blue-50 text-blue-600' when 'completed' then 'bg-green-50 text-green-600' when 'pending' then 'bg-red-50 text-red-600' end %>">
                  <%= case declaration.status when 'declaring' then '宣言中' when 'completed' then '達成' when 'pending' then '未達成' end %>
                </span>
              </td>
              <td class="px-5 py-3 text-sm text-gray-400"><%= declaration.deadline.strftime("%Y/%m/%d") %></td>
              <td class="px-5 py-3 text-right">
                <%= button_to "削除", admin_declaration_path(declaration), method: :delete,
                    data: { turbo_confirm: "この宣言を本当に削除しますか？" },
                    class: "text-red-500 text-sm hover:text-red-700 transition-colors cursor-pointer" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>
