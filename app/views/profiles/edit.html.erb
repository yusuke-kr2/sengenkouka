<% content_for :title, "プロフィール編集 - sengen" %>


<!-- ナビバー -->
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/75 backdrop-blur-md border-b border-gray-200">
  <div class="mx-auto pl-0 pr-6 h-16 flex justify-between items-center max-w-5xl">
    <%= link_to root_path do %>
      <%= image_tag "logo.png", alt: "sengen", class: "h-10 w-auto -ml-12" %>
    <% end %>
    <div class="flex items-center gap-3">
      <%= link_to "キャンセル", profile_path, class: "border border-gray-300 text-gray-600 rounded-lg px-4 py-1.5 text-sm hover:bg-gray-50 transition-colors" %>
    </div>
  </div>
</nav>

<div class="min-h-screen bg-gray-50 pt-16">
  <div class="max-w-2xl mx-auto px-4 py-6">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-800 mb-6">プロフィール編集</h2>

      <%= form_with model: current_user, url: profile_path, method: :patch, multipart: true do |f| %>
        <div class="space-y-4">
          <!-- アバター -->
          <div data-controller="image-preview" class="flex items-center gap-4">
            <div class="h-16 w-16 rounded-full bg-gray-100 flex items-center justify-center shrink-0 overflow-hidden">
              <img data-image-preview-target="preview" src="" class="h-full w-full object-cover hidden">
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, class: "h-full w-full object-cover", data: { "image_preview_target": "placeholder" } %>
              <% else %>
                <svg data-image-preview-target="placeholder" class="h-9 w-9 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              <% end %>
            </div>
            <div>
              <%= f.label :avatar, t("profiles.edit.select_avatar"), class: "block text-sm font-medium text-blue-600 cursor-pointer hover:text-blue-700" %>
              <%= f.file_field :avatar, accept: "image/*", class: "hidden",
                  data: { "image_preview_target": "input", action: "change->image-preview#show" } %>
            </div>
          </div>

          <div>
            <%= f.label :name, "ユーザー名", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_field :name,
                class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
          <div>
            <%= f.label :bio, "自己紹介", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= f.text_area :bio,
                rows: 4,
                placeholder: "自己紹介を入力してください",
                class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
          <%= f.submit "保存する",
              class: "w-full bg-blue-600 text-white rounded-lg py-2.5 text-sm font-semibold hover:bg-blue-700 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
